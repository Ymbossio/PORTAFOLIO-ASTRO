---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  lang: 'es' | 'en';
}

const { title, lang } = Astro.props;
---

<!doctype html>
<html lang={lang} class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={lang === 'es' ? 'Portafolio profesional de Yovanis Bossio, Desarrollador Full Stack. Conoce mis proyectos y experiencia.' : 'Professional portfolio of Yovanis Bossio, Full Stack Developer. Discover my projects and work experience.'} />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <!-- Google Fonts Outfit -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <title>{title}</title>
  </head>
  <body class="bg-slate-950 text-slate-100 min-h-screen flex flex-col relative overflow-x-hidden selection:bg-blue-600/30 selection:text-blue-200">
    <!-- Reading Progress Bar -->
    <div id="scroll-progress" class="fixed top-0 left-0 h-1 bg-gradient-to-r from-blue-600 via-indigo-500 to-cyan-400 z-[100] transition-all duration-75" style="width: 0%;"></div>

    <!-- Dot Grid Background Overlay -->
    <div class="absolute inset-0 -z-50 bg-[radial-gradient(#1e40af_0.75px,transparent_0.75px)] [background-size:24px_24px] opacity-20 pointer-events-none"></div>
    
    <!-- Ambient Futuristic Glows -->
    <div class="absolute top-0 left-[10%] -z-40 w-[24rem] md:w-[40rem] h-[24rem] md:h-[40rem] bg-blue-600/10 rounded-full blur-[100px] pointer-events-none"></div>
    <div class="absolute top-[800px] right-[5%] -z-40 w-[20rem] md:w-[32rem] h-[20rem] md:h-[32rem] bg-indigo-600/10 rounded-full blur-[100px] pointer-events-none"></div>
    <div class="absolute top-[1600px] left-[5%] -z-40 w-[24rem] md:w-[36rem] h-[24rem] md:h-[36rem] bg-cyan-600/10 rounded-full blur-[100px] pointer-events-none"></div>

    <Header lang={lang} />
    <main class="flex-grow z-10">
      <slot />
    </main>
    <Footer lang={lang} />

    <script>
      const updateProgressBar = () => {
        const winScroll = window.scrollY || document.documentElement.scrollTop;
        const height = document.documentElement.scrollHeight - document.documentElement.clientHeight;
        const scrolled = height > 0 ? (winScroll / height) * 100 : 0;
        const progressBar = document.getElementById('scroll-progress');
        if (progressBar) {
          progressBar.style.width = `${scrolled}%`;
        }
      };

      // Listeners
      window.addEventListener('scroll', updateProgressBar);
      window.addEventListener('resize', updateProgressBar);
      
      // Initial trigger
      updateProgressBar();
    </script>
  </body>
</html>

<style is:global>
  :root {
    color-scheme: dark;
  }
  html {
    font-family: 'Outfit', system-ui, sans-serif;
  }
  @media(prefers-reduced-motion: reduce){
    html{
      scroll-behavior: auto;
    }
  }
</style>
