---
import Layout from '../layouts/Layout.astro';
import Card from './Card.astro';
import Experiencia from './Experiencia.astro';
import Proyectos from './Proyectos.astro';
import Skills from './Skills.astro';
import SobreMi from './SobreMi.astro';
import Contacto from './Contacto.astro';
import ExperienciaIcon from './icons/ExperienciaIcon.astro';
import SobreMiIcon from './icons/SobreMi-Icon.astro';
import { useTranslations } from '../i18n/translations';

interface Props {
  lang: 'es' | 'en';
}

const { lang } = Astro.props;
const t = useTranslations(lang);
---

<Layout title={lang === 'es' ? 'Yovanis Bossio | Desarrollador Full Stack' : 'Yovanis Bossio | Full Stack Developer'} lang={lang}>
  <div class="max-w-4xl mx-auto px-4 md:px-6 py-8 md:py-16 space-y-24 md:space-y-36">
    <!-- Hero / Card Section -->
    <section id="inicio" class="scroll-mt-28">
      <Card lang={lang} />
    </section>

    <!-- Experiencia Section -->
    <section id="Experiencia" class="scroll-mt-28">
      <h2 class="text-3xl md:text-4xl font-bold mb-8 md:mb-12 flex gap-x-4 items-center text-white">
        <ExperienciaIcon class="size-8 text-blue-500" />
        {t('experience.title')}
      </h2>
      <Experiencia lang={lang} />
    </section>

    <!-- Proyectos Section -->
    <section id="Proyectos" class="scroll-mt-28">
      <h2 class="text-3xl md:text-4xl font-bold mb-8 md:mb-12 flex gap-x-4 items-center text-white">
        <svg class="size-8 text-blue-500" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M17.25 6.75 22.5 12l-5.25 5.25m-10.5 0L1.5 12l5.25-5.25m7.5-3-4.5 16.5" />
        </svg>
        {t('projects.title')}
      </h2>
      <Proyectos lang={lang} />
    </section>

    <!-- Habilidades / Skills Section -->
    <section id="Tecnologias" class="scroll-mt-28">
      <h2 class="text-3xl md:text-4xl font-bold mb-8 md:mb-12 flex gap-x-4 items-center text-white">
        <svg class="size-8 text-blue-500" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 17.25v1.007a3 3 0 0 1-.879 2.122L7.5 21h9l-.621-.621A3 3 0 0 1 15 18.257V17.25m6-12V15a2.25 2.25 0 0 1-2.25 2.25H5.25A2.25 2.25 0 0 1 3 15V5.25m18 0A2.25 2.25 0 0 0 18.75 3H5.25A2.25 2.25 0 0 0 3 5.25m18 0V12a2.25 2.25 0 0 1-2.25 2.25H5.25A2.25 2.25 0 0 1 3 12V5.25" />
        </svg>
        {t('skills.title')}
      </h2>
      <Skills lang={lang} />
    </section>

    <!-- Sobre Mí Section -->
    <section id="Sobre-mi" class="scroll-mt-28">
      <h2 class="text-3xl md:text-4xl font-bold mb-8 md:mb-12 flex gap-x-4 items-center text-white">
        <SobreMiIcon class="size-8 text-blue-500" />
        {t('about.title')}
      </h2>
      <SobreMi lang={lang} />
    </section>

    <!-- Contacto Section -->
    <section id="Contacto" class="scroll-mt-28">
      <Contacto lang={lang} />
    </section>
  </div>
</Layout>
