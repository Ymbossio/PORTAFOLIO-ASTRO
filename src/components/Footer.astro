---
import { useTranslations } from '../i18n/translations';

interface Props {
  lang: 'es' | 'en';
}

const { lang } = Astro.props;
const t = useTranslations(lang);
const currentYear = new Date().getFullYear();
---

<footer class="w-full max-w-4xl mx-auto px-4 mt-20 mb-10">
  <div class="border-t border-slate-900 pt-8 flex flex-col md:flex-row items-center justify-between gap-4 text-sm text-slate-500">
    <div>
      © {currentYear} 
      <a href="#inicio" class="text-slate-400 hover:text-blue-400 transition font-medium ml-1">
        Yovanis Bossio
      </a>. {t('footer.rights')}
    </div>
    
    <ul class="flex items-center gap-x-6 font-medium">
      <li>
        <a href="#Sobre-mi" class="hover:text-blue-400 transition">
          {t('nav.sobremi')}
        </a>
      </li>
      <li>
        <a href="mailto:Yovanis2001@gmail.com" class="hover:text-blue-400 transition">
          {t('footer.contact')}
        </a>
      </li>
    </ul>
  </div>
</footer>