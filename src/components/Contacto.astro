---
import { useTranslations } from "../i18n/translations";

interface Props {
  lang: "es" | "en";
}

const { lang } = Astro.props;
const t = useTranslations(lang);
---

<div class="grid grid-cols-1 md:grid-cols-12 gap-8 md:gap-12 items-start">
  <!-- Info Column (Left) -->
  <div class="md:col-span-5 space-y-6">
    <div class="space-y-3">
      <h3 class="text-2xl md:text-3xl font-extrabold text-white">
        {t("contact.title")}
      </h3>
      <p class="text-sm md:text-base text-slate-400 font-light leading-relaxed">
        {t("contact.subtitle")}
      </p>
    </div>

    <!-- Details list -->
    <div class="space-y-4 pt-4 text-sm font-medium text-slate-300">
      <div class="flex items-center gap-x-3.5 group">
        <div
          class="flex items-center justify-center size-9 rounded-xl border border-slate-800 bg-slate-900/40 text-blue-500 group-hover:bg-blue-600 group-hover:text-white transition duration-300"
        >
          <svg
            class="size-4"
            fill="none"
            viewBox="0 0 24 24"
            stroke-width="2"
            stroke="currentColor"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75"
            ></path>
          </svg>
        </div>
        <a
          href="mailto:Yovanis2001@gmail.com"
          class="hover:text-blue-400 transition"
        >
          Yovanis2001@gmail.com
        </a>
      </div>

      <div class="flex items-center gap-x-3.5 group">
        <div
          class="flex items-center justify-center size-9 rounded-xl border border-slate-800 bg-slate-900/40 text-blue-500 group-hover:bg-blue-600 group-hover:text-white transition duration-300"
        >
          <svg class="size-4" fill="currentColor" viewBox="0 0 24 24">
            <path
              fill-rule="evenodd"
              clip-rule="evenodd"
              d="M12 2C6.477 2 2 6.477 2 12c0 4.42 2.865 8.166 6.839 9.489.5.092.682-.217.682-.482 0-.237-.008-.866-.013-1.7-2.782.603-3.369-1.34-3.369-1.34-.454-1.156-1.11-1.464-1.11-1.464-.908-.62.069-.608.069-.608 1.003.07 1.531 1.03 1.531 1.03.892 1.529 2.341 1.087 2.91.831.092-.646.35-1.086.636-1.336-2.22-.253-4.555-1.11-4.555-4.943 0-1.091.39-1.984 1.029-2.683-.103-.253-.446-1.27.098-2.647 0 0 .84-.269 2.75 1.025A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.294 2.747-1.025 2.747-1.025.546 1.377.203 2.394.1 2.646.64.699 1.026 1.592 1.026 2.683 0 3.842-2.337 4.687-4.565 4.935.359.309.678.919.678 1.852 0 1.336-.012 2.415-.012 2.743 0 .267.18.579.688.481C19.138 20.162 22 16.418 22 12c0-5.523-4.477-10-10-10z"
            ></path>
          </svg>
        </div>
        <a
          href="https://github.com/Ymbossio"
          target="_blank"
          rel="noopener noreferrer"
          class="hover:text-blue-400 transition"
        >
          github.com/Ymbossio
        </a>
      </div>

      <div class="flex items-center gap-x-3.5 group">
        <div
          class="flex items-center justify-center size-9 rounded-xl border border-slate-800 bg-slate-900/40 text-blue-500 group-hover:bg-blue-600 group-hover:text-white transition duration-300"
        >
          <svg class="size-4" fill="currentColor" viewBox="0 0 24 24">
            <path
              fill-rule="evenodd"
              clip-rule="evenodd"
              d="M12 0c-6.627 0-12 5.373-12 12s5.373 12 12 12 12-5.373 12-12-5.373-12-12-12zm0 22c-5.514 0-10-4.486-10-10s4.486-10 10-10 10 4.486 10 10-4.486 10-10 10zm1.115-15.823l4.575 4.575-1.299 1.299-3.276-3.276-3.276 3.276-1.299-1.299 4.575-4.575 3.276 3.276z"
            ></path>
          </svg>
        </div>
        <a
          href="https://www.linkedin.com/in/ymbossio"
          target="_blank"
          rel="noopener noreferrer"
          class="hover:text-blue-400 transition"
        >
          linkedin.com/in/ymbossio
        </a>
      </div>

      <div class="flex items-center gap-x-3.5 group">
        <div
          class="flex items-center justify-center size-9 rounded-xl border border-slate-800 bg-slate-900/40 text-blue-500 group-hover:bg-blue-600 group-hover:text-white transition duration-300"
        >
          <svg
            class="size-4"
            fill="none"
            viewBox="0 0 24 24"
            stroke-width="2"
            stroke="currentColor"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z"></path>
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25s-7.5-4.108-7.5-11.25a7.5 7.5 0 1 1 15 0Z"
            ></path>
          </svg>
        </div>
        <span class="text-slate-300"> Barranquilla, Atlántico, CO </span>
      </div>
    </div>
  </div>

  <!-- Form Column (Right) -->
  <div class="md:col-span-7 w-full">
    <div
      class="relative w-full rounded-2xl border border-slate-800/80 bg-slate-900/20 backdrop-blur-sm p-6 shadow-[0_10px_35px_rgba(0,0,0,0.4)] overflow-hidden"
    >
      <!-- Glow flare -->
      <div
        class="absolute -z-10 -top-12 -right-12 w-36 h-36 bg-blue-600/10 rounded-full blur-2xl"
      >
      </div>

      <!-- Success Screen -->
      <div
        id="contact-success"
        class="hidden py-8 flex flex-col items-center justify-center text-center space-y-4"
      >
        <div
          class="flex items-center justify-center size-16 rounded-full bg-emerald-950/50 border border-emerald-500/30 text-emerald-400 shadow-[0_0_20px_rgba(16,185,129,0.2)] animate-bounce"
        >
          <svg
            class="size-8"
            fill="none"
            viewBox="0 0 24 24"
            stroke-width="2.5"
            stroke="currentColor"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M4.5 12.75l6 6 9-13.5"></path>
          </svg>
        </div>
        <h4 class="text-xl font-bold text-white">
          {t("contact.success_title")}
        </h4>
        <p class="text-sm text-slate-400 max-w-sm leading-relaxed">
          {t("contact.success_msg")}
        </p>
      </div>

      <!-- Main Form -->
      <form id="contact-form" class="space-y-5">
        <!-- Web3forms access key: Instantly works for free. (Users can replace this or configure their key) -->
        <input
          type="hidden"
          name="access_key"
          value="7e17bcbc-c15c-439f-b7a4-e91b5c2a1380"
        />
        <input
          type="hidden"
          name="subject"
          value="Nuevo Mensaje de Contacto - Portafolio"
        />
        <input
          type="hidden"
          name="from_name"
          value="Yovanis Bossio Portafolio"
        />

        <!-- Name Field -->
        <div class="space-y-1.5">
          <label
            for="form-name"
            class="text-xs font-semibold text-slate-300 tracking-wide uppercase select-none"
            >{t("contact.name")}</label
          >
          <input
            type="text"
            name="name"
            id="form-name"
            required
            placeholder={t("contact.name_placeholder")}
            class="w-full px-4 py-3 rounded-xl border border-slate-800 bg-slate-950/40 focus:border-blue-500/80 focus:bg-slate-950/80 focus:ring-1 focus:ring-blue-500/30 text-slate-100 text-sm placeholder-slate-600 outline-none transition-all duration-300"
          />
        </div>

        <!-- Email Field -->
        <div class="space-y-1.5">
          <label
            for="form-email"
            class="text-xs font-semibold text-slate-300 tracking-wide uppercase select-none"
            >{t("contact.email")}</label
          >
          <input
            type="email"
            name="email"
            id="form-email"
            required
            placeholder={t("contact.email_placeholder")}
            class="w-full px-4 py-3 rounded-xl border border-slate-800 bg-slate-950/40 focus:border-blue-500/80 focus:bg-slate-950/80 focus:ring-1 focus:ring-blue-500/30 text-slate-100 text-sm placeholder-slate-600 outline-none transition-all duration-300"
          />
        </div>

        <!-- Message Field -->
        <div class="space-y-1.5">
          <label
            for="form-message"
            class="text-xs font-semibold text-slate-300 tracking-wide uppercase select-none"
            >{t("contact.message")}</label
          >
          <textarea
            name="message"
            id="form-message"
            rows="4"
            required
            placeholder={t("contact.message_placeholder")}
            class="w-full px-4 py-3 rounded-xl border border-slate-800 bg-slate-950/40 focus:border-blue-500/80 focus:bg-slate-950/80 focus:ring-1 focus:ring-blue-500/30 text-slate-100 text-sm placeholder-slate-600 outline-none transition-all duration-300 resize-none"
          ></textarea>
        </div>

        <!-- Submit Button -->
        <button
          type="submit"
          id="form-submit"
          data-sending={t("contact.sending_btn")}
          data-send={t("contact.send_btn")}
          class="w-full py-3 px-6 rounded-xl bg-blue-600 hover:bg-blue-500 text-white font-semibold text-sm transition duration-300 shadow-[0_0_15px_rgba(37,99,235,0.2)] hover:shadow-[0_0_20px_rgba(37,99,235,0.4)] active:scale-[0.98] select-none"
        >
          {t("contact.send_btn")}
        </button>

        <!-- Error Alert -->
        <div
          id="contact-error"
          class="hidden text-xs text-red-400 bg-red-950/30 border border-red-500/20 p-3 rounded-xl select-none"
        >
          {t("contact.error_msg")}
        </div>
      </form>
    </div>
  </div>
</div>

<script>
  const form = document.getElementById("contact-form") as HTMLFormElement;
  const submitBtn = document.getElementById("form-submit") as HTMLButtonElement;
  const successCard = document.getElementById("contact-success");
  const errorAlert = document.getElementById("contact-error");

  if (form && submitBtn && successCard && errorAlert) {
    const textSending = submitBtn.dataset.sending || "Sending...";
    const textSend = submitBtn.dataset.send || "Send Message";

    form.addEventListener("submit", (e) => {
      e.preventDefault();

      // Lock UI
      submitBtn.disabled = true;
      submitBtn.textContent = textSending;
      errorAlert.classList.add("hidden");

      const formData = new FormData(form);
      const object = Object.fromEntries(formData);
      const json = JSON.stringify(object);

      fetch("https://api.web3forms.com/submit", {
        method: "POST",
        headers: {
          "Content-Type": "application/json",
          Accept: "application/json",
        },
        body: json,
      })
        .then(async (response) => {
          let res = await response.json();
          if (response.status == 200) {
            // Hide Form and Show Success message
            form.classList.add("hidden");
            successCard.classList.remove("hidden");
          } else {
            console.log(response);
            errorAlert.textContent = res.message || errorAlert.textContent;
            errorAlert.classList.remove("hidden");
            submitBtn.disabled = false;
            submitBtn.textContent = textSend;
          }
        })
        .catch((error) => {
          console.log(error);
          errorAlert.classList.remove("hidden");
          submitBtn.disabled = false;
          submitBtn.textContent = textSend;
        });
    });
  }
</script>
