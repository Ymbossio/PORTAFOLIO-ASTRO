---
import { useTranslations } from '../i18n/translations';

interface Props {
  lang: 'es' | 'en';
}

const { lang } = Astro.props;
const t = useTranslations(lang);
---

<div class="grid grid-cols-1 md:grid-cols-12 gap-8 md:gap-12 items-center">
  <!-- Paragraphs (Left Column) -->
  <div class="md:col-span-7 space-y-4 md:space-y-6 order-2 md:order-1">
    <p class="text-sm md:text-base text-slate-350 leading-relaxed font-light">
      {t('about.p1')}
    </p>
    <p class="text-sm md:text-base text-slate-350 leading-relaxed font-light">
      {t('about.p2')}
    </p>
    <p class="text-sm md:text-base text-slate-350 leading-relaxed font-light">
      {t('about.p3')}
    </p>
  </div>

  <!-- Profile Image Frame (Right Column) -->
  <div class="md:col-span-5 flex justify-center order-1 md:order-2">
    <div class="relative group">
      <!-- Glow effect behind the image -->
      <div class="absolute -inset-0.5 bg-gradient-to-tr from-blue-600 via-indigo-500 to-cyan-400 rounded-2xl blur-md opacity-30 group-hover:opacity-60 transition duration-500"></div>
      
      <!-- Frame Border -->
      <div class="relative bg-slate-950 p-1.5 rounded-2xl border border-slate-800/80 shadow-[0_10px_30px_rgba(0,0,0,0.5)] overflow-hidden">
        <!-- Profile Image -->
        <img 
          src="/MePhoto.jpeg" 
          alt="Yovanis Bossio" 
          width="280" 
          height="280" 
          class="rounded-xl w-60 h-60 md:w-64 md:h-64 object-cover grayscale-[20%] hover:grayscale-0 transition duration-500 scale-100 group-hover:scale-[1.02]"
        />
        <!-- Tech Corners -->
        <div class="absolute top-3 left-3 w-3 h-3 border-t-2 border-l-2 border-blue-400"></div>
        <div class="absolute top-3 right-3 w-3 h-3 border-t-2 border-r-2 border-blue-400"></div>
        <div class="absolute bottom-3 left-3 w-3 h-3 border-b-2 border-l-2 border-blue-400"></div>
        <div class="absolute bottom-3 right-3 w-3 h-3 border-b-2 border-r-2 border-blue-400"></div>
      </div>
    </div>
  </div>
</div>
