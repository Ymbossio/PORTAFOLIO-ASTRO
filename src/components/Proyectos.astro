---
import { ui, useTranslations } from '../i18n/translations';

interface Props {
  lang: 'es' | 'en';
}

const { lang } = Astro.props;
const t = useTranslations(lang);
const projects = ui[lang]['projects.list'];
---

<div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-8">
  {projects.map((project) => (
    <div class="group relative rounded-2xl bg-slate-900/30 border border-slate-900 hover:border-slate-800/80 hover:bg-slate-900/50 hover:shadow-[0_10px_30px_rgba(59,130,246,0.03)] overflow-hidden transition-all duration-300 flex flex-col">
      
      <!-- Project Image Wrapper -->
      <div class="relative overflow-hidden aspect-video bg-slate-950/80 border-b border-slate-900 flex items-center justify-center">
        <img 
          src={project.image} 
          alt={project.title} 
          class="w-full h-full object-cover object-top group-hover:scale-[1.03] transition-transform duration-500"
        />
        <!-- Ambient hover screen overlay -->
        <div class="absolute inset-0 bg-gradient-to-t from-slate-950 via-transparent to-transparent opacity-60"></div>
      </div>

      <!-- Project Content -->
      <div class="p-5 md:p-6 flex-grow flex flex-col justify-between space-y-4">
        <div class="space-y-2">
          <h3 class="text-lg md:text-xl font-bold text-white group-hover:text-blue-400 transition-colors duration-300">
            {project.title}
          </h3>
          <p class="text-sm text-slate-400 leading-relaxed font-light line-clamp-3">
            {project.description}
          </p>
        </div>

        <!-- Action Links -->
        <div class="flex items-center gap-x-3 pt-2">
          {project.github && (
            <a 
              href={project.github} 
              target="_blank" 
              rel="noopener noreferrer"
              class="inline-flex items-center gap-x-2 text-xs font-semibold px-4 py-2 rounded-xl bg-slate-900 hover:bg-slate-800 text-slate-200 border border-slate-800 hover:border-slate-700 transition duration-300"
            >
              <svg class="size-4" fill="currentColor" viewBox="0 0 24 24">
                <path fill-rule="evenodd" clip-rule="evenodd" d="M12 2C6.477 2 2 6.477 2 12c0 4.42 2.865 8.166 6.839 9.489.5.092.682-.217.682-.482 0-.237-.008-.866-.013-1.7-2.782.603-3.369-1.34-3.369-1.34-.454-1.156-1.11-1.464-1.11-1.464-.908-.62.069-.608.069-.608 1.003.07 1.531 1.03 1.531 1.03.892 1.529 2.341 1.087 2.91.831.092-.646.35-1.086.636-1.336-2.22-.253-4.555-1.11-4.555-4.943 0-1.091.39-1.984 1.029-2.683-.103-.253-.446-1.27.098-2.647 0 0 .84-.269 2.75 1.025A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.294 2.747-1.025 2.747-1.025.546 1.377.203 2.394.1 2.646.64.699 1.026 1.592 1.026 2.683 0 3.842-2.337 4.687-4.565 4.935.359.309.678.919.678 1.852 0 1.336-.012 2.415-.012 2.743 0 .267.18.579.688.481C19.138 20.162 22 16.418 22 12c0-5.523-4.477-10-10-10z" />
              </svg>
              {t('projects.code_btn')}
            </a>
          )}
          
          {project.link && (
            <a 
              href={project.link} 
              target="_blank" 
              rel="noopener noreferrer"
              class="inline-flex items-center gap-x-2 text-xs font-semibold px-4 py-2 rounded-xl bg-blue-600 hover:bg-blue-500 text-white transition duration-300 shadow-[0_0_10px_rgba(37,99,235,0.15)] hover:shadow-[0_0_15px_rgba(37,99,235,0.3)] border border-transparent"
            >
              <svg class="size-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 0 0 3 8.25v10.5A2.25 2.25 0 0 0 5.25 21h10.5A2.25 2.25 0 0 0 18 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25" />
              </svg>
              {t('projects.live_btn')}
            </a>
          )}
        </div>
      </div>
    </div>
  ))}
</div>
