---
import { ui } from '../i18n/translations';

interface Props {
  lang: 'es' | 'en';
}

const { lang } = Astro.props;
const jobs = ui[lang]['experience.jobs'];
---

<ol class="relative border-s border-slate-800/80 ml-3 md:ml-4 space-y-8 md:space-y-12">
  {jobs.map((job) => (
    <li class="relative group">
      <!-- Glow Node Dot -->
      <div class="absolute w-3.5 h-3.5 bg-blue-600 rounded-full mt-1.5 -start-[28px] md:-start-[32px] border-4 border-slate-950 shadow-[0_0_12px_rgba(37,99,235,0.6)] group-hover:scale-125 group-hover:bg-cyan-400 group-hover:shadow-[0_0_15px_rgba(34,211,238,0.8)] transition-all duration-300"></div>
      
      <!-- Content Card -->
      <div class="p-5 md:p-6 rounded-2xl bg-slate-900/30 border border-slate-900/60 hover:border-slate-800/80 group-hover:bg-slate-900/50 hover:shadow-[0_4px_20px_rgba(37,99,235,0.03)] transition duration-300 space-y-3">
        <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-1.5">
          <h3 class="text-lg md:text-xl font-bold text-white group-hover:text-blue-400 transition-colors duration-300">
            {job.title}
          </h3>
          <time class="text-xs font-semibold tracking-wider text-blue-500/90 uppercase">
            {job.date}
          </time>
        </div>
        
        <p class="text-sm md:text-base text-slate-350 leading-relaxed font-light">
          {job.description}
        </p>
      </div>
    </li>
  ))}
</ol>
